    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@checkmarkdevtools/commitlint-plugin-rai": "^0.1.6",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.3.1",
