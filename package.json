{
  "name": "dev-community-dashboard",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=4096 vitest run --coverage",
    "lhci:desktop": "lhci autorun --collect.settings.preset=desktop",
    "lhci:mobile": "LHCI_MOBILE=1 lhci autorun",
    "format": "prettier --write .",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@checkmarkdevtools/commitlint-plugin-rai": "^0.1.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "tmp": "^0.2.4",
      "brace-expansion@^1.1.0": "1.1.13",
      "flatted": "3.4.2",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "path-to-regexp": "0.1.13",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "next@>=16.0.0-beta.0 <16.2.3": ">=16.2.3",
      "basic-ftp@<=5.2.1": ">=5.2.2",
      "basic-ftp@=5.2.0": ">=5.2.1",
      "basic-ftp@<=5.2.2": ">=5.3.0",
      "uuid@<14.0.0": ">=14.0.0"
    }
