{
  "name": "dev-community-dashboard",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
